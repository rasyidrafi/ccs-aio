# CCS Budget Proxy - Environment Configuration
# Copy this file to .env and fill in the values

# Server port
PORT=8098

# Upstream CLIProxyAPI URL
UPSTREAM_URL=http://127.0.0.1:8097

# JWT secret for management API authentication (generate a random string)
JWT_SECRET=change-me-to-a-random-secret

# Management API credentials
ADMIN_USERNAME=your-username
ADMIN_PASSWORD=your-password

# Path to usage database (read-only, for budget checks)
USAGE_DB_PATH=~/.ccs-dashboard/data/usage-v2.db

# Path to cliproxy config directory (for API key name resolution)
CLIPROXY_CONFIG_DIR=~/.ccs/cliproxy
