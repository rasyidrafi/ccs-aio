{
  "name": "ccs-backup",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "sync": "bun run src/cli.ts sync",
    "sync-live": "bun run src/cli.ts sync-live",
    "sync-snapshot": "bun run src/cli.ts sync-snapshot",
    "status": "bun run src/cli.ts status",
    "backfill-old-data": "bun run src/cli.ts backfill-old-data",
    "rebuild-rollups": "bun run src/cli.ts rebuild-rollups",
    "reprice": "bun run src/cli.ts reprice",
    "test": "bun test",
    "install:systemd": "bash scripts/install-systemd.sh",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^20.19.25",
    "typescript": "5.3"
  }
}
